<!DOCTYPE html>
<html lang="es">
<!-- Include Head -->

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<link width="" rel="shortcut icon" href="./images/logo-mercado-liebre.jpg" />

	<title> Mercado Liebre Argentina</title>
	<!-- Font Awesome Stylesheet -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.11.2/css/all.min.css">
	<!-- Bootstrap Grid Stylesheet -->
	<link rel="stylesheet" href="./css/bootstrap-grid.min.css">
	<!-- Own Stylesheet -->
	<link rel="stylesheet" href="/css/app.css">
</head>

<body>
	<!-- Header -->
	<% if (logueado === false) { %>
		<%- include('partials/header') %>
	<% } else { %>
		<%- include('partials/headerLogedin') %>
	<% } %>
	<!-- /Header -->

	<!-- Novedades -->
<section class="searchResultsContainer">

    <header class="searchResultsHeader">
        <h1 class="searchResultsTitle">Resultados de búsqueda</h1>
        <p class="searchResultsText">Estos son los resultados encontrados para tu búsqueda.</p>
    </header>

    <section class="productsList">

        <article class="productCard">
            <img class="productImage" src="/images/products/iphone13.jpg" alt="iPhone 13">
            <h2 class="productName">iPhone 13</h2>
            <p class="productDescription">Celular Apple de 128GB en excelente estado.</p>
            <a class="productLink" href="/products/detail/1">Ver detalle</a>
        </article>

        <article class="productCard">
            <img class="productImage" src="/images/products/macbookair.jpg" alt="MacBook Air">
            <h2 class="productName">MacBook Air M1</h2>
            <p class="productDescription">Notebook liviana y rápida, ideal para estudio y trabajo.</p>
            <a class="productLink" href="/products/detail/2">Ver detalle</a>
        </article>

        <article class="productCard">
            <img class="productImage" src="/images/products/ps5.jpg" alt="PlayStation 5">
            <h2 class="productName">PlayStation 5</h2>
            <p class="productDescription">Consola de videojuegos de última generación.</p>
            <a class="productLink" href="/products/detail/3">Ver detalle</a>
        </article>

        <article class="productCard">
            <img class="productImage" src="/images/products/nike.jpg" alt="Zapatillas Nike">
            <h2 class="productName">Zapatillas Nike</h2>
            <p class="productDescription">Zapatillas deportivas cómodas para uso diario.</p>
            <a class="productLink" href="/products/detail/4">Ver detalle</a>
        </article>

    </section>

</section>

	<!-- footer -->
	<%- include('partials/footer') %>
	<!-- /footer -->
</body>

</html>