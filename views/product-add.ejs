<!DOCTYPE html>
<html lang="es">
<!-- Include Head -->

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<link width="" rel="shortcut icon" href="./images/logo-mercado-liebre.jpg" />

	<title> Mercado Liebre Argentina</title>
	<!-- Font Awesome Stylesheet -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.11.2/css/all.min.css">
	<!-- Bootstrap Grid Stylesheet -->
	<link rel="stylesheet" href="/css/bootstrap-grid.min.css">
	<!-- Own Stylesheet -->
	<link rel="stylesheet" href="/css/app.css">
</head>

<body>
	<!-- Header -->
	<% if (logueado === false) { %>
		<%- include('partials/header') %>
	<% } else { %>
		<%- include('partials/headerLogedin') %>
	<% } %>
	<!-- /Header -->

	<!-- Novedades -->
<section class="formContainer">

    <header>
        <h1 class="formTitle">Agregar producto</h1>
    </header>

    <form class="formCustom" action="/products/add" method="GET">

        <article class="formGroup">
            <label class="formLabel" for="image">Imagen</label>
            <input class="formInput" type="text" name="image" id="image" required>
        </article>

        <article class="formGroup">
            <label class="formLabel" for="productName">Nombre del producto</label>
            <input class="formInput" type="text" name="productName" id="productName" required>
        </article>

        <article class="formGroup">
            <label class="formLabel" for="description">Descripción</label>
            <textarea class="formTextarea" name="description" id="description" required></textarea>
        </article>

        <footer>
            <button class="formButton" type="submit">Agregar</button>
        </footer>

    </form>

</section>


	<!-- footer -->
	<%- include('partials/footer') %>
	<!-- /footer -->
</body>

</html>