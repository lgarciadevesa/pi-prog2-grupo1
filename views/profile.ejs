<!DOCTYPE html>
<html lang="es">
<!-- Include Head -->

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<link width="" rel="shortcut icon" href="./images/logo-mercado-liebre.jpg" />

	<title> Mercado Liebre Argentina</title>
	<!-- Font Awesome Stylesheet -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.11.2/css/all.min.css">
	<!-- Bootstrap Grid Stylesheet -->
	<link rel="stylesheet" href="/css/bootstrap-grid.min.css">
	<!-- Own Stylesheet -->
	<link rel="stylesheet" href="/css/app.css">
</head>

<body>
	<!-- Header -->
	<% if (logueado===false) { %>
		<%- include('partials/header') %>
			<% } else { %>
				<%- include('partials/headerLogedin') %>
					<% } %>
						<!-- /Header -->

						<!-- Datos del usuario -->
						<section class="info-usuario container products-wrapper">
							<div class="row">
								<div class="img-container offset-3 col-2">
									<img src="<%= usuario.fotoPerfil %>" alt="foto de perfil" class="foto-perfil">
								</div>
								<div class="data-container col-6">
									<div class="d-flex align-items-center ">
										<h1 class="main-title">
											<%= usuario.usuario %>
										</h1>
										<a class="btn mt-3 ml-4" href="">SEGUIR</a>
									</div>
									<div>
										<ul class="">
											<li>Email: <%= usuario.email %>
											</li>
										</ul>
									</div>
								</div>
							</div>
						</section>
						<!-- /Datos del usuario -->

						<!-- Mis productos -->
						<div class="container products-wrapper">
							<div class="row">
								<div class="col-12">
									<h2 class="products-title">Mis productos</h2>
								</div>
								<!-- Show mis productos -->
								<% for (let i=5; i < products.length; i++) { %>
									<div class="col-12 col-sm-6 col-lg-3">
										<section class="product-box">
											<a href="/products/detalle/<%= products[i].id %>">
												<figure class="product-box_image">
													<img src="/images/products/<%= products[i].imagen %>" alt="<%= products[i].nombre %>">
												</figure>
												<article class="product-box_data">
													<h2>
														<%= products[i].nombre %>
													</h2>
													<p>
														<%= products[i].descripcion %>...
													</p>
													<p>Comentarios: <%= products[i].comentarios.length %>
													</p>
												</article>
											</a>
										</section>
									</div>
									<% } %>
								</div>
						</div>
						<!-- /Mis productos -->


						<!-- footer -->
						<%- include('partials/footer') %>
							<!-- /footer -->
</body>

</html>